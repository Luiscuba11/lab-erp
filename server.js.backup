'use strict';

const express = require('express');
const session = require('express-session');
const path = require('path');

const { init: initDB } = require('./db/database');

const app = express();
const PORT = process.env.PORT || 3000;

// ─── Middleware ────────────────────────────────────────────────────────────────

app.use(express.json());
app.use(express.urlencoded({ extended: false }));

app.use(session({
  secret: 'lab-erp-secret-2024-change-in-production',
  resave: false,
  saveUninitialized: false,
  cookie: {
    httpOnly: true,
    maxAge: 8 * 60 * 60 * 1000   // 8 hours
  }
}));

app.use(express.static(path.join(__dirname, 'public')));

// ─── API Routes ────────────────────────────────────────────────────────────────

app.use('/api/auth',      require('./routes/auth'));
app.use('/api/patients',  require('./routes/patients'));
app.use('/api/orders',    require('./routes/orders'));
app.use('/api/catalog',   require('./routes/catalog'));
app.use('/api/results',   require('./routes/results'));
app.use('/api/dashboard', require('./routes/dashboard'));
app.use('/api/users',     require('./routes/users'));
app.use('/api/supplies',  require('./routes/supplies'));
app.use('/report',        require('./routes/reports'));
app.use('/api/billing',        require('./routes/billing'));
app.use('/api/finance',        require('./routes/finance'));
app.use('/api/notifications',  require('./routes/notifications'));

// ─── SPA Fallback ──────────────────────────────────────────────────────────────

app.get('*', (req, res) => {
  res.sendFile(path.join(__dirname, 'public', 'index.html'));
});

// ─── Global Error Handler ──────────────────────────────────────────────────────

app.use((err, req, res, next) => {
  console.error('[ERROR]', err.message, err.stack);
  res.status(500).json({ error: 'Internal server error', detail: err.message });
});

// ─── Start ─────────────────────────────────────────────────────────────────────

initDB()
  .then(() => {
    app.listen(PORT, () => {
      console.log(`\n  LabERP is running at http://localhost:${PORT}`);
      console.log(`\n  Default accounts:`);
      console.log(`    admin         / admin123   (ADMIN)`);
      console.log(`    receptionist  / rec123     (RECEPTIONIST)`);
      console.log(`    technician    / tech123    (TECHNICIAN)`);
      console.log(`    biochemist    / bio123     (BIOCHEMIST)\n`);
    });
  })
  .catch(err => {
    console.error('[FATAL] Database initialization failed:', err);
    process.exit(1);
  });
