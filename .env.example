# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3004

# ─── Database ─────────────────────────────────────────────────────────────────
# Use "sqlite" for local dev, "postgres" for production cloud
DB_TYPE=sqlite
DB_PATH=./data/lab.db

# PostgreSQL (only used when DB_TYPE=postgres)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=biopap_db
DB_USER=biopap_user
DB_PASSWORD=change_me_in_production

# ─── Session / Auth ───────────────────────────────────────────────────────────
SESSION_SECRET=change_this_to_a_random_64_char_string_in_production
JWT_SECRET=change_this_jwt_secret_in_production
JWT_EXPIRES_IN=8h

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3004
